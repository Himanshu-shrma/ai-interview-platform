# AI Interview Platform — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM ───────────────────────────────────────────────────────────────────────
# OpenAI API key. Used for GPT-4o (Interviewer Agent, Evaluation Agent)
# and GPT-4o-mini (Reasoning Analyzer, Follow-Up Generator, Hint Generator).
OPENAI_API_KEY=sk-...

# ── Auth (Clerk.dev) ──────────────────────────────────────────────────────────
# Create a Clerk application at https://dashboard.clerk.com (free tier is fine).
# Both keys are available in Clerk Dashboard → API Keys.
CLERK_SECRET_KEY=sk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...
# JWKS URL format: https://<your-clerk-frontend-api>/.well-known/jwks.json
# Found in Clerk Dashboard → API Keys → Advanced
CLERK_JWKS_URL=https://your-clerk-instance.clerk.accounts.dev/.well-known/jwks.json

# ── Application Database (PostgreSQL) ────────────────────────────────────────
# Used by the backend via R2DBC (async). Docker Compose exposes port 5432.
POSTGRES_DB=aiinterview
POSTGRES_USER=aiinterview
POSTGRES_PASSWORD=changeme
# R2DBC connection string for Spring Boot application.yml
DATABASE_URL=r2dbc:postgresql://localhost:5432/aiinterview

# ── Application Redis ─────────────────────────────────────────────────────────
# Used for session memory (TTL snapshots), rolling transcript, rate limiting,
# and free-tier usage counters. Docker Compose exposes port 6379.
REDIS_URL=redis://localhost:6379

# ── Code Execution (Judge0 CE) ────────────────────────────────────────────────
# Judge0 runs locally via Docker Compose on port 2358 (internal, not public).
# JUDGE0_AUTH_TOKEN must match AUTHN_TOKEN in judge0/judge0.conf.
JUDGE0_BASE_URL=http://localhost:2358
JUDGE0_AUTH_TOKEN=judge0_dev_token_replace_in_production
JUDGE0_AUTH_HEADER=X-Auth-Token

# Judge0 internal DB/Redis passwords (must match judge0/judge0.conf)
JUDGE0_DB_PASSWORD=judge0secret
JUDGE0_REDIS_PASSWORD=judge0secret

# ── Frontend (Vite) ───────────────────────────────────────────────────────────
# Copy these into frontend/.env.local (also gitignored).
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...
VITE_API_BASE_URL=http://localhost:8080
VITE_WS_URL=ws://localhost:8080
